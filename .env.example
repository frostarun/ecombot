# Copy this file to .env and fill in your keys.
# The demo loads it automatically through python-dotenv.

# LLM provider
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM gateway:
# - direct: ADK/LiteLLM calls OpenRouter model names directly
# - proxy: ADK/LiteLLM calls local LiteLLM proxy model groups
LLM_GATEWAY_MODE=direct
LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000
LITELLM_PROXY_API_KEY=sk-ecombot-local

# Logical model groups. Defaults keep both routes on Gemini 2.5 Flash; change
# ECOMBOT_DEEP_MODEL if you want deep-support to use a stronger model.
ECOMBOT_FAST_ROUTE=fast-faq
ECOMBOT_DEEP_ROUTE=deep-support
ECOMBOT_FAST_MODEL=openrouter/google/gemini-2.5-flash
ECOMBOT_DEEP_MODEL=openrouter/google/gemini-2.5-flash

# FastMCP external backend tools
ECOMBOT_ENABLE_MCP_TOOLS=true
ECOMBOT_MCP_TIMEOUT_SECONDS=8
ECOMBOT_MCP_HOST=127.0.0.1
ECOMBOT_MCP_PORT=8775
ECOMBOT_MCP_URL=http://127.0.0.1:8775/mcp
ECOMBOT_MCP_TRANSPORT=streamable-http

# Optional observability placeholder for later modules
LANGSMITH_API_KEY=

# Session backend:
# - database: ADK sessions in PostgreSQL, Redis used for snapshots/session refs
# - redis: ADK sessions in Redis through adk-extra-services
# - memory: local fallback, no persistence
SESSION_BACKEND=database

# PostgreSQL
PG_HOST=localhost
PG_PORT=5433
PG_DB=ecombot
PG_USER=ecombot
PG_PASSWORD=pg_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_secret
REDIS_SESSION_TTL=3600
